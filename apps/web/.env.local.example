# CastFlow web — copy to .env.local and fill in.
# Every var the web app reads is NEXT_PUBLIC_* (exposed to the browser).
# Do NOT put server secrets here.

# --- Required ---

# API origin. The fetcher calls ${NEXT_PUBLIC_API_URL}/api/v1.
# Local: http://localhost:3001 — Staging/Prod: the deployed API origin.
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket origin for real-time messaging. Usually the API origin with a
# ws:// (local) or wss:// (staging/prod) scheme. If unset, messaging falls
# back to REST polling (no live push).
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Public marketing-site origin. Used for canonical URLs, Open Graph, sitemap
# and robots. MUST be set per environment — if unset it falls back to the
# production hostname, which would make a staging deploy emit production URLs.
# Local: http://localhost:3000 — Staging: https://staging.castflow.co.uk
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deploy environment. Only 'production' is crawlable/indexable. Set anything
# else (e.g. 'staging', 'preview', 'development') on non-prod deploys so the
# site emits robots.txt `disallow: /` and a global noindex meta tag.
NEXT_PUBLIC_SITE_ENV=development

# --- Optional ---

# Cloudflare Turnstile site key for registration CAPTCHA. Leave unset to
# disable the widget (the API's captcha middleware is gated by the same flag).
# Pair with TURNSTILE_SECRET_KEY on the API.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Demo only. When 'true', the public Talent/Shoots pages fall back to bundled
# mock data if the API returns nothing — useful for an empty demo environment.
# Leave unset/false on staging and prod so real empty states show instead of
# fabricated artists/shoots.
# NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=false
