NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/castflow

BETTER_AUTH_SECRET=change-this-to-a-random-string-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3001

STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
# Recurring price the caster subscribes to (the only platform charge).
STRIPE_PRICE_ID=price_your_subscription_price_id

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_PUBLIC_BUCKET=castflow-public
R2_PRIVATE_BUCKET=castflow-private
R2_CONTRACTS_BUCKET=castflow-contracts
R2_PUBLIC_URL=https://pub.your-custom-domain.com
# Set to `eu` (or `fedramp`) when your buckets use jurisdictional data
# residency — they're only reachable on the matching S3 endpoint. Leave unset
# for the default endpoint.
R2_JURISDICTION=

RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@castflow.co.uk

FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Dev only: when 'true' AND NODE_ENV != 'production', new signups are auto-
# verified so you can log in without configuring Resend. Production ignores it.
DEV_AUTO_VERIFY_EMAIL=true
