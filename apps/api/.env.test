# Test-only env overrides. Loaded by Bun whenever NODE_ENV=test, layered on
# top of `.env` so only DATABASE_URL flips — every other secret/key is the
# placeholder defined in `.env` and the test suite mocks the SDKs that read
# them (Stripe, R2, Resend).
#
# Points at the local Postgres started by `docker-compose.yml`. Port 5433
# avoids colliding with any system-installed Postgres on 5432.

DATABASE_URL="postgresql://castflow:castflow_test@localhost:5436/castflow_test?sslmode=disable"
